---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { site } from '../config/site';

import construccion from '../assets/servicio-construccion.jpg';
import reparacion from '../assets/servicio-reparacion.jpg';
import conversion from '../assets/servicio-conversion.jpg';
import diqueSeco from '../assets/servicio-dique-seco.jpg';

// Imágenes en el mismo orden que site.services.
const images = [construccion, reparacion, conversion, diqueSeco];
---

<Layout title="Servicios — Atlantic Marine">
  <main class="mx-auto max-w-6xl px-6 pb-28 pt-32 sm:pt-40">
    <p class="text-xs uppercase tracking-[0.25em] text-accent">Qué hacemos</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl">Servicios</h1>
    <p class="mt-6 max-w-xl text-lg leading-relaxed text-steel">
      De la construcción a la reparación y el mantenimiento, cubrimos el ciclo de
      vida completo del buque. Contenido de ejemplo mientras preparamos el real.
    </p>

    <div class="mt-24 space-y-24 sm:mt-28 sm:space-y-32">
      {
        site.services.map((service, i) => (
          <article class="grid items-center gap-10 sm:grid-cols-2 sm:gap-16">
            <div
              class:list={[
                'overflow-hidden rounded-xl border border-line shadow-lg shadow-black/30',
                i % 2 === 1 && 'sm:order-2',
              ]}
            >
              <Image
                src={images[i]}
                alt={service.title}
                class="aspect-[3/2] w-full object-cover"
              />
            </div>

            <div class:list={[i % 2 === 1 && 'sm:order-1']}>
              <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">{service.title}</h2>
              <p class="mt-5 leading-relaxed text-steel">{service.detail}</p>
              <ul class="mt-8 space-y-3 border-t border-line pt-8">
                {service.includes.map((item) => (
                  <li class="flex items-start gap-3 text-sm text-fog">
                    <span class="mt-0.5 shrink-0 text-accent" aria-hidden="true">
                      →
                    </span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </main>
</Layout>

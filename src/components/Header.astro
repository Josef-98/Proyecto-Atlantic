---
// Cabecera común: logo + navegación de escritorio + menú hamburguesa (móvil).
import { site } from '../config/site';
---

<header class="absolute inset-x-0 top-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-6">
    <!-- Logo / nombre -->
    <a
      href="/"
      class="text-sm font-semibold uppercase tracking-[0.25em] text-fog transition-colors hover:text-accent"
    >
      {site.name}
    </a>

    <!-- Navegación de escritorio -->
    <nav class="hidden items-center gap-10 md:flex">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="text-xs uppercase tracking-[0.15em] text-fog/85 transition-colors hover:text-fog"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Botón hamburguesa (solo móvil) -->
    <button
      type="button"
      id="menu-open"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="text-fog md:hidden"
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>

  <!-- Menú móvil a pantalla completa (oculto por defecto) -->
  <div id="mobile-menu" class="fixed inset-0 z-50 hidden bg-ink/95 backdrop-blur-sm">
    <div class="flex items-center justify-between px-6 py-6">
      <span class="text-sm font-semibold uppercase tracking-[0.25em] text-fog">
        {site.name}
      </span>
      <button type="button" id="menu-close" aria-label="Cerrar menú" class="text-fog">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>

    <nav class="mt-10 flex flex-col items-center gap-8">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="text-2xl font-medium uppercase tracking-wide text-fog transition-colors hover:text-accent"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const openBtn = document.getElementById('menu-open');
  const closeBtn = document.getElementById('menu-close');
  const menu = document.getElementById('mobile-menu');

  const setOpen = (show: boolean) => {
    menu?.classList.toggle('hidden', !show);
    openBtn?.setAttribute('aria-expanded', String(show));
    document.body.style.overflow = show ? 'hidden' : '';
  };

  openBtn?.addEventListener('click', () => setOpen(true));
  closeBtn?.addEventListener('click', () => setOpen(false));
  // Al pulsar un enlace, cerrar el menú.
  menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setOpen(false)));
</script>

---
// Cabecera común: logo (vuelve al inicio) + navegación.
// Los datos vienen del archivo de contenido, no van escritos aquí.
import { site } from '../config/site';
---

<header>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-6">
    <!-- Logo / nombre: único sitio donde aparece el nombre; enlaza a la home -->
    <a
      href="/"
      class="text-sm font-semibold uppercase tracking-[0.25em] text-fog transition-colors hover:text-accent"
    >
      {site.name}
    </a>

    <!-- Navegación (se oculta en móvil; el menú hamburguesa llega en un paso posterior) -->
    <nav class="hidden items-center gap-10 md:flex">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="text-xs uppercase tracking-[0.15em] text-steel transition-colors hover:text-fog"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

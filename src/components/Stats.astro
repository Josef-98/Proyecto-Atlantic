---
// Contadores de credibilidad. Los datos vienen del archivo de contenido.
import { site } from '../config/site';
---

<section class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
    <div class="grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-4">
      {
        site.stats.map((stat) => (
          <div>
            <p class="text-4xl font-semibold tracking-tight text-fog sm:text-5xl">
              {stat.value}
            </p>
            <p class="mt-2 text-xs uppercase tracking-[0.15em] text-steel">
              {stat.label}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

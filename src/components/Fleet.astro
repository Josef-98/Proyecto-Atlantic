---
// Sección de flota en la home: cabecera + rejilla reutilizable + enlace "Ver todos".
import FleetGrid from './FleetGrid.astro';
---

<section class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-accent">Portfolio</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">Nuestra flota</h2>
      </div>
      <a
        href="/flota"
        class="hidden items-center gap-1 text-sm font-medium text-accent transition-colors hover:text-fog sm:inline-flex"
      >
        Ver todos <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="mt-12">
      <FleetGrid limit={3} />
    </div>
  </div>
</section>

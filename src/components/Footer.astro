---
// Footer común: marca + zona + navegación + copyright. Sin dirección exacta.
import { site } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-14">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-fog">
        {site.name}
      </p>
      <p class="mt-3 text-sm text-steel">Astillero naval</p>
      <p class="mt-1 text-sm text-steel">{site.location}</p>
    </div>

    <div class="mt-12 border-t border-line pt-6">
      <p class="text-xs text-steel">
        © {year} {site.name}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>

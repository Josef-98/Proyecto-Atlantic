---
// Bloques de servicios: tarjeta con foto + título + frase + "Más info".
// Textos desde el archivo de contenido; imágenes importadas aquí (astro:assets).
import { Image } from 'astro:assets';
import { site } from '../config/site';

import construccion from '../assets/servicio-construccion.jpg';
import reparacion from '../assets/servicio-reparacion.jpg';
import conversion from '../assets/servicio-conversion.jpg';
import diqueSeco from '../assets/servicio-dique-seco.jpg';

// Imágenes en el mismo orden que site.services.
const images = [construccion, reparacion, conversion, diqueSeco];
---

<section class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    <p class="text-xs uppercase tracking-[0.25em] text-accent">Qué hacemos</p>
    <h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">Servicios</h2>

    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        site.services.map((service, i) => (
          <article class="group overflow-hidden rounded-lg border border-line bg-surface transition-colors hover:border-steel">
            <div class="aspect-[16/10] overflow-hidden">
              <Image
                src={images[i]}
                alt={service.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-6">
              <h3 class="text-lg font-semibold text-fog">{service.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-steel">{service.description}</p>
              <a
                href="/servicios"
                class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent transition-colors hover:text-fog"
              >
                Más info <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
